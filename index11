<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>STF SOG14 OSINT</title>
    <style>
        :root {
            --bg-color: #060a13;
            --panel-bg: #0f172a;
            --border-color: #1e293b;
            --text-main: #f8fafc;
            --text-muted: #94a3b8;
            --error-red: #f43f5e;
            --success-green: #10b981;
            
            /* Color Themes */
            --db1-blue: #38bdf8;
            --db1-glow: rgba(56, 189, 248, 0.15);
            --db2-green: #10b981;
            --db2-glow: rgba(16, 185, 129, 0.15);
            --imei-purple: #a855f7;
            --imei-glow: rgba(168, 85, 247, 0.15);
            --orange-link: #f97316;
            --orange-glow: rgba(249, 115, 22, 0.15);
        }

        body {
            font-family: 'Courier New', Courier, monospace, -apple-system, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-main);
            margin: 0;
            padding: 20px;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            box-sizing: border-box;
        }

        .container {
            background: var(--panel-bg);
            padding: 30px;
            border-radius: 16px;
            border: 1px solid var(--border-color);
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.6);
            width: 100%;
            max-width: 650px;
            position: relative;
            overflow: hidden;
        }

        .container::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 3px;
            background: linear-gradient(90deg, transparent, var(--db1-blue), var(--orange-link), var(--db2-green), transparent);
        }

        h1 {
            margin-top: 0;
            font-size: 26px;
            text-align: center;
            color: #ffffff;
            letter-spacing: 3px;
            text-transform: uppercase;
            text-shadow: 0 0 8px rgba(255,255,255,0.2);
            margin-bottom: 5px;
        }

        p.subtitle {
            text-align: center;
            color: var(--text-muted);
            font-size: 11px;
            margin-bottom: 30px;
            text-transform: uppercase;
            letter-spacing: 1.5px;
        }

        .search-mode-toggle {
            display: flex;
            background: #020617;
            border: 1px solid var(--border-color);
            border-radius: 8px;
            padding: 4px;
            margin-bottom: 25px;
        }

        .toggle-btn {
            flex: 1;
            background: transparent;
            border: none;
            color: var(--text-muted);
            padding: 10px;
            font-size: 12px;
            font-weight: bold;
            font-family: inherit;
            cursor: pointer;
            border-radius: 6px;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .toggle-btn.active[data-mode="phone"] {
            background: rgba(56, 189, 248, 0.15);
            color: var(--db1-blue);
            border: 1px solid rgba(56, 189, 248, 0.3);
        }

        .toggle-btn.active[data-mode="imei"] {
            background: rgba(168, 85, 247, 0.15);
            color: var(--imei-purple);
            border: 1px solid rgba(168, 85, 247, 0.3);
        }

        .input-group {
            position: relative;
            margin-bottom: 20px;
        }

        input[type="text"] {
            width: 100%;
            padding: 14px 16px;
            background-color: #020617;
            border: 1px solid var(--border-color);
            border-radius: 8px;
            box-sizing: border-box;
            font-size: 16px;
            color: #ffffff;
            outline: none;
            transition: all 0.3s ease;
            font-family: inherit;
        }

        input[type="text"]:focus {
            border-color: var(--db1-blue);
            box-shadow: 0 0 12px var(--db1-glow);
        }

        body.imei-active input[type="text"]:focus {
            border-color: var(--imei-purple);
            box-shadow: 0 0 12px var(--imei-glow);
        }

        button.exec-btn {
            width: 100%;
            background: linear-gradient(135deg, #0284c7, #0369a1);
            color: white;
            border: none;
            padding: 14px;
            font-size: 15px;
            font-weight: bold;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.2s ease;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            font-family: inherit;
            box-shadow: 0 4px 12px rgba(3, 105, 161, 0.3);
        }

        body.imei-active button.exec-btn {
            background: linear-gradient(135deg, #7c3aed, #6d28d9);
            box-shadow: 0 4px 12px rgba(109, 40, 217, 0.3);
        }

        .loading {
            text-align: center;
            display: none;
            margin-top: 20px;
            font-size: 13px;
            letter-spacing: 1px;
            animation: pulse 1.5s infinite;
        }
        body:not(.imei-active) .loading { color: var(--db1-blue); }
        body.imei-active .loading { color: var(--imei-purple); }

        @keyframes pulse {
            0%, 100% { opacity: 0.6; }
            50% { opacity: 1; }
        }

        .result-box {
            margin-top: 30px;
            display: none;
        }

        .server-section {
            margin-bottom: 25px;
            padding: 20px;
            border-radius: 12px;
            background: #090f1c;
        }

        .server-section.db1-theme { border: 1px solid rgba(56, 189, 248, 0.15); box-shadow: 0 4px 20px rgba(0,0,0,0.2), inset 0 0 15px var(--db1-glow); }
        .server-section.db2-theme { border: 1px solid rgba(16, 185, 129, 0.15); box-shadow: 0 4px 20px rgba(0,0,0,0.2), inset 0 0 15px var(--db2-glow); }
        .server-section.imei-theme { border: 1px solid rgba(168, 85, 247, 0.15); box-shadow: 0 4px 20px rgba(0,0,0,0.2), inset 0 0 15px var(--imei-glow); }
        .server-section.recursive-theme { border: 1px solid rgba(249, 115, 22, 0.2); box-shadow: 0 4px 20px rgba(0,0,0,0.2), inset 0 0 15px var(--orange-glow); }

        .server-header {
            display: flex;
            justify-content: space-between;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 15px;
            padding-bottom: 8px;
            font-weight: bold;
        }

        .db1-theme .server-header { color: var(--db1-blue); border-bottom: 1px dashed rgba(56, 189, 248, 0.2); }
        .db2-theme .server-header { color: var(--db2-green); border-bottom: 1px dashed rgba(16, 185, 129, 0.2); }
        .imei-theme .server-header { color: var(--imei-purple); border-bottom: 1px dashed rgba(168, 85, 247, 0.2); }
        .recursive-theme .server-header { color: var(--orange-link); border-bottom: 1px dashed rgba(249, 115, 22, 0.2); }

        .records-container {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .record-card {
            background: #030712;
            border-radius: 8px;
            padding: 14px;
            border: 1px solid #1e293b;
        }
        
        .recursive-theme .record-card { border: 1px solid rgba(249, 115, 22, 0.25); margin-bottom: 10px; }

        .record-title {
            font-size: 11px;
            margin-bottom: 12px;
            font-weight: bold;
            padding-left: 8px;
        }
        
        .db1-theme .record-title { border-left: 3px solid var(--db1-blue); color: var(--db1-blue); }
        .db2-theme .record-title { border-left: 3px solid var(--db2-green); color: var(--db2-green); }
        .imei-theme .record-title { border-left: 3px solid var(--imei-purple); color: var(--imei-purple); }
        .recursive-theme .record-title { border-left: 3px solid var(--orange-link); color: var(--orange-link); }

        .result-item {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 10px;
            font-size: 14px;
            border-bottom: 1px solid #111827;
            padding-bottom: 6px;
        }

        .result-item:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }

        .telecom-meta-block {
            background-color: #090f1c;
            border: 1px solid #1e293b;
            border-radius: 6px;
            padding: 10px 12px;
            margin-top: 12px;
        }

        .meta-row {
            display: flex;
            justify-content: space-between;
            font-size: 13px;
            padding: 5px 0;
            border-bottom: 1px dashed #030712;
        }

        .meta-row:last-child { border-bottom: none; }
        .meta-label { color: var(--text-muted); }
        .meta-val { color: #ffffff; font-weight: bold; text-align: right; word-break: break-all; }

        .label-with-icon {
            display: flex;
            align-items: center;
            gap: 10px;
            color: var(--text-muted);
            white-space: nowrap;
        }

        .label-with-icon svg {
            width: 16px;
            height: 16px;
            fill: none;
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        .db1-theme .label-with-icon svg { stroke: var(--db1-blue); }
        .db2-theme .label-with-icon svg { stroke: var(--db2-green); }
        .imei-theme .label-with-icon svg { stroke: var(--imei-purple); }
        .recursive-theme .label-with-icon svg { stroke: var(--orange-link); }

        .result-item span.res-value {
            color: #ffffff;
            font-weight: bold;
            text-align: right;
            word-break: break-word;
            padding-left: 15px;
        }

        .res-value a.status-link {
            text-decoration: none;
            font-weight: bold;
            color: var(--db2-green);
            border: 1px solid rgba(16, 185, 129, 0.3);
            background: rgba(16, 185, 129, 0.1);
            padding: 2px 6px;
            border-radius: 4px;
            font-size: 12px;
            transition: all 0.2s ease;
            display: inline-block;
        }

        .recursive-theme .res-value a.status-link {
            color: var(--orange-link);
            border: 1px solid rgba(249, 115, 22, 0.3);
            background: rgba(249, 115, 22, 0.1);
        }

        .res-value a.status-link:hover {
            background: var(--db2-green);
            color: #000000;
            box-shadow: 0 0 8px var(--db2-green);
        }

        .recursive-theme .res-value a.status-link:hover {
            background: var(--orange-link);
            color: #000000;
            box-shadow: 0 0 8px var(--orange-link);
        }

        .inner-error {
            font-size: 13px;
            text-align: center;
            padding: 10px;
            color: var(--text-muted);
        }

        .error-box {
            margin-top: 20px;
            padding: 12px;
            border-radius: 8px;
            background: rgba(244, 63, 94, 0.1);
            color: var(--error-red);
            border: 1px solid rgba(244, 63, 94, 0.3);
            display: none;
            font-size: 14px;
            text-align: center;
        }
    </style>
</head>
<body>

<div class="container" id="mainContainer">
    <h1>STF SOG14 OSINT</h1>
    
    <div class="search-mode-toggle">
        <button class="toggle-btn active" data-mode="phone" onclick="switchMode('phone')">Phone Search</button>
        <button class="toggle-btn" data-mode="imei" onclick="switchMode('imei')">IMEI Search</button>
    </div>
    
    <div class="input-group">
        <input type="text" id="targetInput" placeholder="Enter 10-digit mobile number" onkeydown="handleKeyPress(event)">
    </div>
    <button class="exec-btn" onclick="executeSearch()">Execute Query</button>

    <div id="loadingText" class="loading">> PINNING TELEMETRY MATRICES... FETCHING LIVE STREAMS...</div>
    <div id="errorBox" class="error-box"></div>

    <div id="resultBox" class="result-box">
        
        <div id="phoneResultsGroup">
            <div class="server-section db1-theme">
                <div class="server-header">
                    <span>[CORE_A] DB-1: TRUE CALL MATRIX</span>
                    <span id="timeDb1" style="color: var(--text-muted);">--</span>
                </div>
                <div id="db1Wrapper" class="records-container"></div>
            </div>

            <div class="server-section db2-theme">
                <div class="server-header">
                    <span>[CORE_B] DB-2: SHERLOCK ENGINE</span>
                    <span id="timeDb2" style="color: var(--text-muted);">--</span>
                </div>
                <div id="db2Wrapper" class="records-container"></div>
            </div>
            
            <div class="server-section recursive-theme" id="recursiveSection" style="display:none;">
                <div class="server-header">
                    <span>[CORE_LINK] // ASSOCIATED TARGET LINKAGE REPORTS</span>
                    <span id="recursiveCount" style="color: var(--text-muted);">0 Linked Matches</span>
                </div>
                <div id="recursiveWrapper" class="records-container"></div>
            </div>
        </div>

        <div id="imeiResultsGroup" style="display:none;">
            <div class="server-section imei-theme">
                <div class="server-header">
                    <span>[CORE_C] DB-3: HICELLTEK TAC MATRIX</span>
                    <span id="timeImei" style="color: var(--text-muted);">--</span>
                </div>
                <div id="imeiWrapper" class="records-container"></div>
            </div>
        </div>

    </div>
</div>

<script>
let currentMode = 'phone';
const HICELLTEK_API_TOKEN = 'WRITE_YOUR_HICELLTEK_API_TOKEN_HERE';

function switchMode(mode) {
    currentMode = mode;
    const input = document.getElementById('targetInput');
    const buttons = document.querySelectorAll('.toggle-btn');
    buttons.forEach(btn => btn.classList.remove('active'));
    document.querySelector(`.toggle-btn[data-mode="${mode}"]`).classList.add('active');
    
    if(mode === 'phone') {
        document.body.classList.remove('imei-active');
        input.placeholder = "Enter 10-digit mobile number";
    } else {
        document.body.classList.add('imei-active');
        input.placeholder = "Enter 15-digit IMEI terminal ID";
    }
}

function handleKeyPress(event) {
    if (event.key === "Enter") executeSearch();
}

function executeSearch() {
    if (currentMode === 'phone') performPhoneLookup();
    else performImeiLookup();
}

function cleanTo10Digits(inputStr) {
    if (!inputStr) return null;
    let digits = inputStr.replace(/\D/g, '');
    if (digits.length === 12 && digits.startsWith('91')) digits = digits.substring(2);
    else if (digits.length === 11 && digits.startsWith('0')) digits = digits.substring(1);
    return digits.length === 10 ? digits : null;
}

async function performPhoneLookup() {
    let rawInput = document.getElementById('targetInput').value;
    const loadingText = document.getElementById('loadingText');
    const resultBox = document.getElementById('resultBox');
    const errorBox = document.getElementById('errorBox');
    
    document.getElementById('phoneResultsGroup').style.display = 'block';
    document.getElementById('imeiResultsGroup').style.display = 'none';
    document.getElementById('recursiveSection').style.display = 'none';
    
    const db1Wrapper = document.getElementById('db1Wrapper');
    const db2Wrapper = document.getElementById('db2Wrapper');
    const recursiveWrapper = document.getElementById('recursiveWrapper');

    resultBox.style.display = 'none';
    errorBox.style.display = 'none';
    db1Wrapper.innerHTML = ''; 
    db2Wrapper.innerHTML = '';
    recursiveWrapper.innerHTML = '';

    let mainNumber = cleanTo10Digits(rawInput);

    if (!mainNumber) {
        errorBox.innerText = `CRITICAL CONFIG FAULT:\nInput must resolve to exactly 10 digits.`;
        errorBox.style.display = 'block';
        return;
    }

    loadingText.style.display = 'block';
    loadingText.innerText = "> PINNING TELEMETRY MATRICES... FETCHING LIVE STREAMS...";

    let processedNumbers = new Set();
    processedNumbers.add(mainNumber);

    const urlDb1 = `https://true-call-check.vercel.app/api/truecallcheckApi?IndNum=${mainNumber}`;
    const urlDb2 = `https://api-developers-sherlock-osint.sherlock-dev.workers.dev/api/number`;

    const startDb1 = performance.now();
    const fetchDb1 = fetch(urlDb1).then(async r => {
        if(!r.ok) throw new Error();
        return { data: await r.json(), time: (performance.now() - startDb1).toFixed(0) };
    });

    const startDb2 = performance.now();
    const fetchDb2 = fetch(urlDb2, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'User-Agent': 'Mozilla/5.0' },
        body: JSON.stringify({ number: '+91' + mainNumber })
    }).then(async r => {
        if(!r.ok) throw new Error();
        return { data: await r.json(), time: (performance.now() - startDb2).toFixed(0) };
    });

    const results = await Promise.allSettled([fetchDb1, fetchDb2]);
    loadingText.style.display = 'none';
    resultBox.style.display = 'block';

    let discoveryQueue = [];

    // Parse DB-1 Primary
    if (results[0].status === "fulfilled") {
        document.getElementById('timeDb1').innerText = `[${results[0].value.time}ms]`;
        const rawResponse = results[0].value.data;
        if (rawResponse && rawResponse.data && Array.isArray(rawResponse.data) && rawResponse.data.length > 0) {
            rawResponse.data.forEach((record, index) => {
                const card = document.createElement('div');
                card.className = 'record-card';
                let operatorName = 'N/A', circleName = record.circle || 'N/A';
                if (record.circle && record.circle.includes(';')) {
                    const parts = record.circle.split(';');
                    operatorName = parts[0]; circleName = parts[1];
                }

                if(record.mobile) {
                    let mClean = cleanTo10Digits(record.mobile);
                    if(mClean && !processedNumbers.has(mClean)) {
                        discoveryQueue.push(mClean);
                        processedNumbers.add(mClean);
                    }
                }

                ['alt_mobile', 'alt_mobile2', 'alt_mobile3', 'alt_mobile4'].forEach(k => {
                    if(record[k]) {
                        let cleaned = cleanTo10Digits(record[k]);
                        if(cleaned && !processedNumbers.has(cleaned)) {
                            discoveryQueue.push(cleaned);
                            processedNumbers.add(cleaned);
                        }
                    }
                });

                card.innerHTML = `
                    <div class="record-title">[PROFILE_ENTRY_0${index + 1}]</div>
                    <div class="result-item"><div class="label-with-icon"><svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg><strong>Full Name:</strong></div><span class="res-value">${record.name || 'NOT_DECLARED'}</span></div>
                    <div class="result-item"><div class="label-with-icon"><svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path></svg><strong>Father Name:</strong></div><span class="res-value">${record.father_name || 'N/A'}</span></div>
                    <div class="result-item"><div class="label-with-icon"><svg viewBox="0 0 24 24"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"></rect></svg><strong>Mobile:</strong></div><span class="res-value">${record.mobile || 'N/A'}</span></div>
                    <div class="result-item"><div class="label-with-icon"><svg viewBox="0 0 24 24"><path d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"></path></svg><strong>Address:</strong></div><span class="res-value">${record.address || 'N/A'}</span></div>
                    <div class="telecom-meta-block">
                        <div class="meta-row"><span class="meta-label">Operator:</span><span class="meta-val">${operatorName}</span></div>
                        <div class="meta-row"><span class="meta-label">Circle:</span><span class="meta-val">${circleName}</span></div>
                        <div class="meta-row"><span class="meta-label">Document No:</span><span class="meta-val">${record.DocumentNumber || 'N/A'}</span></div>
                        <div class="meta-row"><span class="meta-label">Email:</span><span class="meta-val">${record.email || 'N/A'}</span></div>
                        <div class="meta-row"><span class="meta-label">Alt Num 1:</span><span class="meta-val">${record.alt_mobile || 'N/A'}</span></div>
                        <div class="meta-row"><span class="meta-label">Alt Num 2:</span><span class="meta-val">${record.alt_mobile2 || 'N/A'}</span></div>
                        <div class="meta-row"><span class="meta-label">Alt Num 3:</span><span class="meta-val">${record.alt_mobile3 || 'N/A'}</span></div>
                        <div class="meta-row"><span class="meta-label">Alt Num 4:</span><span class="meta-val">${record.alt_mobile4 || 'N/A'}</span></div>
                    </div>
                `;
                db1Wrapper.appendChild(card);
            });
        } else { db1Wrapper.innerHTML = '<div class="inner-error">> No matching records in Core Alpha database.</div>'; }
    } else { db1Wrapper.innerHTML = '<div class="inner-error">CORE_A SYSTEM FAULT</div>'; }

    // Parse DB-2 Primary
    if (results[1].status === "fulfilled") {
        document.getElementById('timeDb2').innerText = `[${results[1].value.time}ms]`;
        const r2 = results[1].value.data;
        if (r2 && r2.success && r2.data) {
            const d = r2.data; const social = d.social || {};
            const whatsappField = social.whatsapp ? `<a href="https://wa.me/91${mainNumber}" target="_blank" class="status-link">ACTIVE</a>` : `<span style="color:var(--error-red);">INACTIVE</span>`;
            const telegramField = social.telegram ? `<a href="https://t.me/+91${mainNumber}" target="_blank" class="status-link">ACTIVE</a>` : `<span style="color:var(--error-red);">INACTIVE</span>`;

            const card = document.createElement('div');
            card.className = 'record-card';
            card.innerHTML = `
                <div class="record-title">[OSINT_INDEX_SIGNATURE]</div>
                <div class="result-item"><div class="label-with-icon"><svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path></svg><strong>ID Name:</strong></div><span class="res-value">${d.name || 'UNKNOWN'}</span></div>
                <div class="result-item"><div class="label-with-icon"><svg viewBox="0 0 24 24"><path d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"></path></svg><strong>Location:</strong></div><span class="res-value">${d.location || 'N/A'}</span></div>
                <div class="result-item"><div class="label-with-icon"><svg viewBox="0 0 24 24"><path d="M2 22h20M2 17h20"></path></svg><strong>Carrier:</strong></div><span class="res-value">${d.carrier || 'N/A'}</span></div>
                <div class="result-item"><div class="label-with-icon"><svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg><strong>WhatsApp:</strong></div><span class="res-value">${whatsappField}</span></div>
                <div class="result-item"><div class="label-with-icon"><svg viewBox="0 0 24 24"><line x1="22" y1="2" x2="11" y2="13"></line></svg><strong>Telegram:</strong></div><span class="res-value">${telegramField}</span></div>
            `;
            db2Wrapper.appendChild(card);
        } else { db2Wrapper.innerHTML = '<div class="inner-error">> No matching signatures logged in Core Beta cluster.</div>'; }
    } else { db2Wrapper.innerHTML = '<div class="inner-error">CORE_B SYSTEM FAULT</div>'; }

    // DYNAMIC RECURSIVE UNIQUE TRACE PIPELINE
    if(discoveryQueue.length > 0) {
        document.getElementById('recursiveSection').style.display = 'block';
        
        while(discoveryQueue.length > 0) {
            let altNum = discoveryQueue.shift();
            document.getElementById('recursiveCount').innerText = `Running Multi-Core Trace On Unified Node: ${altNum}...`;

            const recursiveUrlDb1 = `https://true-call-check.vercel.app/api/truecallcheckApi?IndNum=${altNum}`;
            const recursiveUrlDb2 = `https://api-developers-sherlock-osint.sherlock-dev.workers.dev/api/number`;

            const runRecDb1 = fetch(recursiveUrlDb1).then(r => r.ok ? r.json() : null).catch(() => null);
            const runRecDb2 = fetch(recursiveUrlDb2, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'User-Agent': 'Mozilla/5.0' },
                body: JSON.stringify({ number: '+91' + altNum })
            }).then(r => r.ok ? r.json() : null).catch(() => null);

            try {
                const subResults = await Promise.all([runRecDb1, runRecDb2]);
                const db1Data = subResults[0];
                const db2Data = subResults[1];

                if ((db1Data && db1Data.data && db1Data.data.length > 0) || (db2Data && db2Data.success && db2Data.data)) {
                    
                    // DEEP NESTED SCAN FOR EXTENDED RECURSION LOOPS
                    if(db1Data && db1Data.data && db1Data.data.length > 0) {
                        db1Data.data.forEach(subRecord => {
                            if(subRecord.mobile) {
                                let cleanMob = cleanTo10Digits(subRecord.mobile);
                                if(cleanMob && !processedNumbers.has(cleanMob)) {
                                    discoveryQueue.push(cleanMob);
                                    processedNumbers.add(cleanMob);
                                }
                            }
                            ['alt_mobile', 'alt_mobile2', 'alt_mobile3', 'alt_mobile4'].forEach(k => {
                                if(subRecord[k]) {
                                    let cleanAlt = cleanTo10Digits(subRecord[k]);
                                    if(cleanAlt && !processedNumbers.has(cleanAlt)) {
                                        discoveryQueue.push(cleanAlt);
                                        processedNumbers.add(cleanAlt);
                                    }
                                }
                            });
                        });
                    }

                    // COMPILE SEAMLESS RENDER FOR LINKED MATRIX CARD
                    const altCard = document.createElement('div');
                    altCard.className = 'record-card';
                    let baseHtml = `<div class="record-title">[LINKED_RELATION_REPORT: ${altNum}]</div>`;
                    
                    // DB-1 Profile Data Integration
                    if(db1Data && db1Data.data && db1Data.data.length > 0) {
                        const rec = db1Data.data[0];
                        let operatorName = 'N/A', circleName = rec.circle || 'N/A';
                        if (rec.circle && rec.circle.includes(';')) {
                            const parts = rec.circle.split(';');
                            operatorName = parts[0]; circleName = parts[1];
                        }
                        
                        baseHtml += `
                            <div class="result-item"><div class="label-with-icon"><svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg><strong>Full Name:</strong></div><span class="res-value" style="color:var(--orange-link);">${rec.name || 'NOT_DECLARED'}</span></div>
                            <div class="result-item"><div class="label-with-icon"><svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path></svg><strong>Father Name:</strong></div><span class="res-value">${rec.father_name || 'N/A'}</span></div>
                            <div class="result-item"><div class="label-with-icon"><svg viewBox="0 0 24 24"><path d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"></path></svg><strong>Address:</strong></div><span class="res-value">${rec.address || 'N/A'}</span></div>
                            <div class="telecom-meta-block">
                                <div class="meta-row"><span class="meta-label">Operator:</span><span class="meta-val">${operatorName}</span></div>
                                <div class="meta-row"><span class="meta-label">Circle:</span><span class="meta-val">${circleName}</span></div>
                                <div class="meta-row"><span class="meta-label">Document No:</span><span class="meta-val">${rec.DocumentNumber || 'N/A'}</span></div>
                                <div class="meta-row"><span class="meta-label">Email:</span><span class="meta-val">${rec.email || 'N/A'}</span></div>
                                <div class="meta-row"><span class="meta-label">Alt Num 1:</span><span class="meta-val">${rec.alt_mobile || 'N/A'}</span></div>
                                <div class="meta-row"><span class="meta-label">Alt Num 2:</span><span class="meta-val">${rec.alt_mobile2 || 'N/A'}</span></div>
                                <div class="meta-row"><span class="meta-label">Alt Num 3:</span><span class="meta-val">${rec.alt_mobile3 || 'N/A'}</span></div>
                                <div class="meta-row"><span class="meta-label">Alt Num 4:</span><span class="meta-val">${rec.alt_mobile4 || 'N/A'}</span></div>
                        `;
                    } else {
                        baseHtml += `<div class="result-item"><div class="label-with-icon"><svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path></svg><strong>Full Name:</strong></div><span class="res-value" style="color:var(--text-muted);">NOT REGISTERED IN DB-1</span></div>`;
                    }

                    // DB-2 Sherlock Profile Data Integration (Explicitly added per request for every single link)
                    if(db2Data && db2Data.success && db2Data.data) {
                        const d2 = db2Data.data; const soc2 = d2.social || {};
                        const waLink = soc2.whatsapp ? `<a href="https://wa.me/91${altNum}" target="_blank" class="status-link">ACTIVE</a>` : `<span style="color:var(--error-red);">INACTIVE</span>`;
                        const tgLink = soc2.telegram ? `<a href="https://t.me/+91${altNum}" target="_blank" class="status-link">ACTIVE</a>` : `<span style="color:var(--error-red);">INACTIVE</span>`;
                        
                        if(baseHtml.includes("telecom-meta-block")) {
                            baseHtml += `
                                <div class="meta-row"><span class="meta-label">Sherlock Name:</span><span class="meta-val" style="color: var(--db2-green);">${d2.name || 'UNKNOWN'}</span></div>
                                <div class="meta-row"><span class="meta-label">OSINT Location:</span><span class="meta-val">${d2.location || 'N/A'}</span></div>
                                <div class="meta-row"><span class="meta-label">Carrier Network:</span><span class="meta-val">${d2.carrier || 'N/A'}</span></div>
                                <div class="meta-row"><span class="meta-label">WhatsApp Node:</span><span class="meta-val">${waLink}</span></div>
                                <div class="meta-row"><span class="meta-label">Telegram Node:</span><span class="meta-val">${tgLink}</span></div>
                            </div>`; 
                        } else {
                            baseHtml += `
                            <div class="telecom-meta-block">
                                <div class="meta-row"><span class="meta-label">Sherlock Name:</span><span class="meta-val" style="color: var(--db2-green);">${d2.name || 'UNKNOWN'}</span></div>
                                <div class="meta-row"><span class="meta-label">OSINT Location:</span><span class="meta-val">${d2.location || 'N/A'}</span></div>
                                <div class="meta-row"><span class="meta-label">Carrier Network:</span><span class="meta-val">${d2.carrier || 'N/A'}</span></div>
                                <div class="meta-row"><span class="meta-label">WhatsApp Node:</span><span class="meta-val">${waLink}</span></div>
                                <div class="meta-row"><span class="meta-label">Telegram Node:</span><span class="meta-val">${tgLink}</span></div>
                            </div>`;
                        }
                    } else {
                        // Append trailing structural element if second core failed
                        if(baseHtml.includes("telecom-meta-block")) {
                            baseHtml += `
                                <div class="meta-row"><span class="meta-label" style="color: var(--error-red);">Sherlock Core:</span><span class="meta-val" style="color: var(--error-red);">INDEX SIGNATURE FAULT</span></div>
                            </div>`;
                        }
                    }

                    altCard.innerHTML = baseHtml;
                    recursiveWrapper.appendChild(altCard);
                }
            } catch(e) { console.error("Link Core deep sub-query fault.", e); }
        }
        document.getElementById('recursiveCount').innerText = `${recursiveWrapper.children.length} Comprehensive Profile Reports Extracted`;
    }
}

async function performImeiLookup() {
    let rawInput = document.getElementById('targetInput').value;
    const loadingText = document.getElementById('loadingText');
    const resultBox = document.getElementById('resultBox');
    const errorBox = document.getElementById('errorBox');
    const imeiWrapper = document.getElementById('imeiWrapper');

    document.getElementById('phoneResultsGroup').style.display = 'none';
    document.getElementById('imeiResultsGroup').style.display = 'block';
    resultBox.style.display = 'none'; errorBox.style.display = 'none'; imeiWrapper.innerHTML = '';

    let imeiDigits = rawInput.replace(/\D/g, '');
    if (imeiDigits.length !== 15) {
        errorBox.innerText = `CRITICAL CONFIG FAULT:\nInput must be a valid 15-digit IMEI structural array.`;
        errorBox.style.display = 'block'; return;
    }

    let tacCode = imeiDigits.substring(0, 8);
    loadingText.style.display = 'block';
    loadingText.innerText = `... SLICING TAC SIGNATURE [${tacCode}]... EXTRACTING FROM HICELLTEK MATRIX CORES...`;
    
    const startTime = performance.now();
    const url = `https://imei.hicelltek.com/api/v1/tac/lookup?tac=${tacCode}`;

    try {
        const response = await fetch(url, { 
            method: 'GET',
            headers: { 'Authorization': `Bearer ${HICELLTEK_API_TOKEN}`, 'Accept': 'application/json' }
        });
        loadingText.style.display = 'none';
        if (!response.ok) throw new Error();

        const resData = await response.json();
        resultBox.style.display = 'block';
        document.getElementById('timeImei').innerText = `[${(performance.now() - startTime).toFixed(0)}ms]`;

        if (resData && (resData.success || resData.status === "success" || resData.data)) {
            const obj = resData.data || resData.result || resData;
            const card = document.createElement('div');
            card.className = 'record-card';
            card.innerHTML = `
                <div class="record-title">[HARDWARE_TAC_SIGNATURE_MATCH]</div>
                <div class="result-item"><div class="label-with-icon"><svg viewBox="0 0 24 24"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"></rect></svg><strong>Brand / Make:</strong></div><span class="res-value">${obj.brand || 'UNKNOWN'}</span></div>
                <div class="result-item"><div class="label-with-icon"><svg viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5z"></path></svg><strong>Model Name:</strong></div><span class="res-value">${obj.model || 'UNKNOWN'}</span></div>
                <div class="telecom-meta-block">
                    <div class="meta-row"><span class="meta-label">Manufacturer:</span><span class="meta-val">${obj.manufacturer || 'N/A'}</span></div>
                    <div class="meta-row"><span class="meta-label">Device Type:</span><span class="meta-val">${obj.type || 'N/A'}</span></div>
                    <div class="meta-row"><span class="meta-label">Specs / Frequency:</span><span class="meta-val">${obj.specifications || 'GSM / LTE / 5G'}</span></div>
                </div>
            `;
            imeiWrapper.appendChild(card);
        } else { imeiWrapper.innerHTML = `<div class="inner-error">> No hardware profiles match this TAC footprint.</div>`; }
    } catch (error) {
        loadingText.style.display = 'none';
        errorBox.innerText = `TAC CORE BLOCK INTERCEPT ERROR. Check Token configurations.`;
        errorBox.style.display = 'block';
    }
}
</script>
